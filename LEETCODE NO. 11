class Solution:
    def maxArea(self, height: List[int]) -> int:
        n=len(height)
        i=0
        j=n-1
        maxarea=0
        while i <j:
            smaller=min(height[i],height[j])
            currentarea=smaller*(j-i)
            maxarea=max(maxarea,currentarea)

            if height[i]<height[j]:
                i+=1
            else:
                j-=1
        return maxarea
        
